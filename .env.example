# tt-rag ingestion pipeline configuration.
# Copy to `.env` and fill in. Every var maps to a `python -m src.ingestion.pipeline` flag.

# --- Required ---------------------------------------------------------------

# Local directory of source files to ingest (recursive; .pdf and .docx).
SOURCE_DIR=./docs

# libpq DSN. Matches the docker-compose Postgres (host port 5444, user/pass/db = ttrag).
DATABASE_DSN=postgresql://ttrag:ttrag@localhost:5444/ttrag

# API key for the embeddings endpoint.
API_KEY=your-api-key-here

CHAT_MODEL=chat-model-here
# --- Embeddings -------------------------------------------------------------

# Base URL of the OpenAI-compatible embeddings API.
OPENAI_BASE_URL=https://api.deepinfra.com/v1/

# Provider name recorded in the extraction config (provenance only).
EMBEDDING_PROVIDER=deepinfra

# Embedding model id.
EMBEDDING_MODEL=BAAI/bge-m3

# Embedding dimensionality (MUST match the schema's VECTOR size).
EMBEDDING_SIZE=1024

# --- Chunking (optional; defaults shown) ------------------------------------

# Target chunk size for the recursive chunker.
CHUNK_SIZE=8123

# Minimum characters per chunk.
MIN_CHARACTERS_PER_CHUNK=24

# Tokenizer used to measure chunk size: "character" or "gpt2".
TOKENIZER=character

# --- Behaviour (optional) ---------------------------------------------------

# Drop and recreate existing tables without prompting. Set to 1/true to enable.
OVERWRITE=false
